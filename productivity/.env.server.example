## === Docker Compose server env ===
## Скопируй в .env.server и заполни.

# Образы (после push в Docker Hub)
BACKEND_IMAGE=sensh1/realty-app:backend-latest
FRONTEND_IMAGE=sensh1/realty-app:frontend-latest

# Postgres
POSTGRES_DB=productivity
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# Django
SECRET_KEY=CHANGE_ME_LONG_RANDOM_SECRET
ALLOWED_HOSTS=YOUR_DOMAIN_OR_IP,localhost,127.0.0.1
DEBUG=False

# CORS (домен фронта)
CORS_ALLOWED_ORIGINS=http://YOUR_DOMAIN_OR_IP,https://YOUR_DOMAIN

